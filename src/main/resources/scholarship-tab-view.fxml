<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #F8F9FA;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.java.controller.ScholarshipTabController">
    <content>
        <VBox spacing="25.0" style="-fx-background-color: #F8F9FA;">
            <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Button fx:id="btnBack" mnemonicParsing="false" style="-fx-background-color: #E0E0E0; -fx-background-radius: 10;" text="← Back" textFill="#495057">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblName" text="Scholarship Name" textFill="#212529">
                                    <font><Font name="System Bold" size="28.0" /></font>
                                </Label>
                                <Label fx:id="lblSponsor" text="Provider / Organization Name" textFill="#800000">
                                    <font><Font size="16.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <Label fx:id="lblStatus" style="-fx-background-color: #D4EDDA; -fx-text-fill: #155724; -fx-padding: 8 15; -fx-background-radius: 20;" text="OPEN" />
                    </children>
                </HBox>
                <GridPane hgap="20.0" vgap="20.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="65.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="35.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <VBox spacing="20.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: #E0E0E0;">
                            <children>
                                <Label text="Description" textFill="#2c3e50">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>
                                <TextFlow>
                                    <children>
                                        <Label fx:id="lblDescription" text="Detailed scholarship description goes here..." wrapText="true" />
                                    </children>
                                </TextFlow>

                                <Separator prefWidth="200.0" />

                                <Label text="Eligibility Criteria" textFill="#2c3e50">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>
                                <VBox spacing="10.0">
                                    <children>
                                        <Label fx:id="lblAcademicReq" text="• Academic: Min Grade 85%" />
                                        <Label fx:id="lblOtherReq" text="• Other: Course, Income, Age bracket details" />
                                    </children>
                                </VBox>

                                <Separator prefWidth="200.0" />

                                <Label text="Application Process" textFill="#2c3e50">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>
                                <Label fx:id="lblProcess" text="Short steps on how to apply..." wrapText="true" />
                            </children>
                        </VBox>
                        <VBox spacing="20.0" GridPane.columnIndex="1">
                            <children>
                                <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: #E0E0E0;">
                                    <children>
                                        <Label text="At a Glance" textFill="#2c3e50">
                                            <font><Font name="System Bold" size="16.0" /></font>
                                        </Label>
                                        <VBox spacing="12.0">
                                            <children>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <Label text="💰 Grant:" textFill="#6c757d" />
                                                        <Label fx:id="lblAward" text="Full Tuition" textFill="#212529"><font><Font name="System Bold" size="12.0" /></font></Label>
                                                    </children>
                                                </HBox>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <Label text="📅 Deadline:" textFill="#6c757d" />
                                                        <Label fx:id="lblDeadline" text="Oct 24, 2026" textFill="#212529"><font><Font name="System Bold" size="12.0" /></font></Label>
                                                    </children>
                                                </HBox>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <Label text="📍 Location:" textFill="#6c757d" />
                                                        <Label fx:id="lblLocation" text="Cebu City (Local)" textFill="#212529"><font><Font name="System Bold" size="12.0" /></font></Label>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        <Button fx:id="btnApply" maxWidth="1.7976931348623157E308" prefHeight="45.0" style="-fx-background-color: #800000; -fx-background-radius: 10;" text="Apply Now" textFill="WHITE">
                                            <font><Font name="System Bold" size="14.0" /></font>
                                        </Button>
                                    </children>
                                </VBox>

                                <VBox spacing="15.0" style="-fx-background-color: #FFF3CD; -fx-padding: 20; -fx-background-radius: 15;">
                                    <children>
                                        <Label text="Documents Needed" textFill="#856404">
                                            <font><Font name="System Bold" size="14.0" /></font>
                                        </Label>
                                        <Label fx:id="lblDocuments" text="- Report Card&#10;- Brgy Clearance&#10;- Parent's ITR" textFill="#856404" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </GridPane>
            </children>
        </VBox>
    </content>
</ScrollPane>

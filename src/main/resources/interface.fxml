<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainPane" maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="800.0" prefWidth="1280.0"
            style="-fx-background-color: #F8F9FA;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="main.java.controller.InterfaceController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0"
              style="-fx-background-color: #800000; -fx-border-color: #FFD700; -fx-border-width: 0 0 4 0;"
              BorderPane.alignment="CENTER">
            <children>
                <Label text="Scholarsheesh" textFill="WHITE">
                    <font><Font name="System Bold" size="28.0"/></font>
                    <HBox.margin><Insets left="30.0"/></HBox.margin>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Label style="-fx-cursor: hand;" text="🔔" textFill="WHITE">
                            <font><Font size="20.0"/></font>
                        </Label>
                        <Separator orientation="VERTICAL" prefHeight="30.0" style="-fx-opacity: 0.5;"/>
                        <VBox alignment="CENTER_RIGHT">
                            <children>
                                <Label fx:id="labelUserName" text="USER NAME" textFill="WHITE">
                                    <font><Font name="System Bold" size="16.0"/></font>
                                </Label>
                                <Label fx:id="labelUserRole" text="Student" textFill="#ffd700">
                                    <font><Font size="12.0"/></font>
                                </Label>
                            </children>
                        </VBox>
                        <Circle fill="WHITE" radius="22.0" stroke="#ffd700" strokeType="INSIDE"/>
                    </children>
                    <HBox.margin><Insets right="30.0"/></HBox.margin>
                </HBox>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="260.0" spacing="10.0"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #DEE2E6; -fx-border-width: 0 1 0 0;"
              BorderPane.alignment="CENTER">
            <children>

                <Button fx:id="btnDashboard" onMouseClicked="#showHome"
                        alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="220.0"
                        style="-fx-background-color: #800000; -fx-background-radius: 10; -fx-cursor: hand;"
                        text="🏠 Dashboard" textFill="WHITE">
                    <font><Font name="System Bold" size="16.0"/></font>
                    <padding><Insets left="20.0"/></padding>
                </Button>

                <Button fx:id="btnScholarships" onMouseClicked="#showScholarshipList"
                        alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="220.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        text="🎓 Scholarships" textFill="#495057">
                    <font><Font size="16.0"/></font>
                    <padding><Insets left="20.0"/></padding>
                </Button>

                <Button fx:id="btnMyApplications" onMouseClicked="#showMyApplications"
                        alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="220.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        text="📄 My Applications" textFill="#495057">
                    <font><Font size="16.0"/></font>
                    <padding><Insets left="20.0"/></padding>
                </Button>

                <Button fx:id="btnDonate" onMouseClicked="#showDonate"
                        alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="220.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        text="💸 Donate" textFill="#495057"
                        visible="false" managed="false">
                    <font><Font size="16.0"/></font>
                    <padding><Insets left="20.0"/></padding>
                </Button>

                <Button fx:id="btnAdminPanel" onMouseClicked="#showAdminPanel"
                        alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="220.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        text="⚙ Admin Panel" textFill="#495057"
                        visible="false" managed="false">
                    <font><Font size="16.0"/></font>
                    <padding><Insets left="20.0"/></padding>
                </Button>

                <Button fx:id="btnProfile" onMouseClicked="#showProfile"
                        alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="220.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        text="👤 My Profile" textFill="#495057">
                    <font><Font size="16.0"/></font>
                    <padding><Insets left="20.0"/></padding>
                </Button>

                <Region VBox.vgrow="ALWAYS"/>
                <Separator prefWidth="200.0"/>

                <Button onMouseClicked="#handleLogout"
                        alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="220.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        text="🚪 Log Out" textFill="#e74c3c">
                    <font><Font name="System Bold" size="16.0"/></font>
                    <padding><Insets left="20.0"/></padding>
                </Button>
            </children>
            <padding><Insets bottom="30.0" left="20.0" right="20.0" top="30.0"/></padding>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: #F8F9FA; -fx-border-color: transparent;">
            <content>
                <StackPane>
                    <children>
                        <Label text="Select a tab to begin" textFill="#bdc3c7">
                            <font><Font size="20.0"/></font>
                        </Label>
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
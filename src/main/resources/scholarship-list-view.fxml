<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="25.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.java.controller.ScholarshipListController">
    <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
    <children>
        <VBox spacing="5.0">
            <children>
                <Label text="Scholarship List" textFill="#212529">
                    <font><Font name="System Bold" size="32.0" /></font>
                </Label>
                <Label text="Fresh opportunities retrieved directly from our database." textFill="#6c757d" />
            </children>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: #E0E0E0; -fx-border-radius: 15;">
            <children>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Search" textFill="#2c3e50"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <TextField fx:id="txtSearch" prefHeight="45.0" promptText="Enter keywords..." style="-fx-background-radius: 10;" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label text="Location" textFill="#2c3e50"><font><Font name="System Bold" size="12.0" /></font></Label>
                        <ComboBox fx:id="comboLocation" prefHeight="45.0" prefWidth="180.0" style="-fx-background-radius: 10;" />
                    </children>
                </VBox>

                <VBox spacing="8.0" prefWidth="250.0">
                    <children>
                        <HBox spacing="10.0">
                            <children>
                                <Label text="Your Grade:" textFill="#2c3e50"><font><Font name="System Bold" size="12.0" /></font></Label>
                                <Label fx:id="lblGradeValue" text="75" textFill="#800000"><font><Font name="System Bold" size="14.0" /></font></Label>
                            </children>
                        </HBox>
                        <Slider fx:id="sliderGrade" max="100.0" min="75.0" value="75.0" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <TableView fx:id="tableScholarships" VBox.vgrow="ALWAYS" style="-fx-background-radius: 15;">
            <columns>
                <TableColumn fx:id="colName" prefWidth="300.0" text="Scholarship Name" />
                <TableColumn fx:id="colSponsor" prefWidth="200.0" text="Sponsor" />
                <TableColumn fx:id="colGrade" prefWidth="150.0" text="Min. Grade" />
                <TableColumn fx:id="colLocation" prefWidth="200.0" text="Location" />
            </columns>
        </TableView>
    </children>
</VBox>
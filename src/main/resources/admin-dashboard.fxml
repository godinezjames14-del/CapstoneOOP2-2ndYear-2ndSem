<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: #F8F9FA;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="main.java.controller.AdminDashboardController">
    <content>
        <VBox spacing="35.0" style="-fx-padding: 40;">
            <children>

                <!-- PAGE HEADER -->
                <VBox spacing="4.0">
                    <children>
                        <Label text="Admin Control Panel" textFill="#212529">
                            <font><Font name="System Bold" size="32.0"/></font>
                        </Label>
                        <Label text="Manage scholarships, funds, and users across the platform." textFill="#6C757D">
                            <font><Font size="15.0"/></font>
                        </Label>
                    </children>
                </VBox>

                <!-- OVERVIEW STATS -->
                <HBox spacing="20.0">
                    <children>

                        <!-- Total Funds -->
                        <VBox prefHeight="110.0" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-border-color: #800000; -fx-border-width: 0 0 0 5;">
                            <effect><DropShadow color="#0000001a" radius="10"/></effect>
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <children>
                                <Label text="💰  Total Funds Collected" textFill="#6C757D"/>
                                <Label fx:id="lblTotalFunds" text="₱0.00" textFill="#800000">
                                    <font><Font name="System Bold" size="28.0"/></font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Total Scholarships -->
                        <VBox prefHeight="110.0" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-border-color: #FFD700; -fx-border-width: 0 0 0 5;">
                            <effect><DropShadow color="#0000001a" radius="10"/></effect>
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <children>
                                <Label text="🎓  Total Scholarships" textFill="#6C757D"/>
                                <Label fx:id="lblTotalScholarships" text="0" textFill="#856404">
                                    <font><Font name="System Bold" size="28.0"/></font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Students -->
                        <VBox prefHeight="110.0" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-border-color: #28a745; -fx-border-width: 0 0 0 5;">
                            <effect><DropShadow color="#0000001a" radius="10"/></effect>
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <children>
                                <Label text="🎒  Registered Students" textFill="#6C757D"/>
                                <Label fx:id="lblTotalStudents" text="0" textFill="#155724">
                                    <font><Font name="System Bold" size="28.0"/></font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Sponsors -->
                        <VBox prefHeight="110.0" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-border-color: #17a2b8; -fx-border-width: 0 0 0 5;">
                            <effect><DropShadow color="#0000001a" radius="10"/></effect>
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <children>
                                <Label text="🏢  Registered Sponsors" textFill="#6C757D"/>
                                <Label fx:id="lblTotalSponsors" text="0" textFill="#117a8b">
                                    <font><Font name="System Bold" size="28.0"/></font>
                                </Label>
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <!-- SCHOLARSHIP MANAGEMENT -->
                <VBox spacing="20.0"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-border-color: #E0E0E0; -fx-border-radius: 15; -fx-padding: 30;">
                    <effect><DropShadow color="#0000001a" radius="10"/></effect>
                    <children>

                        <Label text="🎓  Scholarship Management" textFill="#212529">
                            <font><Font name="System Bold" size="20.0"/></font>
                        </Label>
                        <Label text="Add, edit, activate or deactivate scholarships." textFill="#6C757D"/>

                        <TableView fx:id="tableScholarships" prefHeight="220.0">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colSchID"       text="ID"        prefWidth="50"/>
                                <TableColumn fx:id="colSchName"     text="Name"      prefWidth="210"/>
                                <TableColumn fx:id="colSchSponsor"  text="Sponsor"   prefWidth="160"/>
                                <TableColumn fx:id="colSchGrade"    text="Min Grade" prefWidth="90"/>
                                <TableColumn fx:id="colSchLocation" text="Location"  prefWidth="120"/>
                                <TableColumn fx:id="colSchStatus"   text="Status"    prefWidth="80"/>
                                <TableColumn fx:id="colSchActions"  text="Actions"   prefWidth="220"/>
                            </columns>
                            <placeholder><Label text="No scholarships found." textFill="#bdc3c7"/></placeholder>
                        </TableView>

                        <!-- Add / Edit Form -->
                        <VBox spacing="15.0"
                              style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-border-color: #dee2e6; -fx-border-radius: 10; -fx-padding: 20;">
                            <children>
                                <Label text="Add / Edit Scholarship" textFill="#495057">
                                    <font><Font name="System Bold" size="15.0"/></font>
                                </Label>

                                <GridPane hgap="15.0" vgap="12.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="33.0"/>
                                        <ColumnConstraints percentWidth="33.0"/>
                                        <ColumnConstraints percentWidth="34.0"/>
                                    </columnConstraints>
                                    <children>
                                        <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                            <children>
                                                <Label text="Scholarship Name *" textFill="#2c3e50"><font><Font name="System Bold" size="12"/></font></Label>
                                                <TextField fx:id="txtSchName" promptText="e.g. Academic Excellence Grant" style="-fx-background-radius: 8;"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <children>
                                                <Label text="Sponsor Name *" textFill="#2c3e50"><font><Font name="System Bold" size="12"/></font></Label>
                                                <TextField fx:id="txtSchSponsor" promptText="e.g. CIT-University" style="-fx-background-radius: 8;"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                            <children>
                                                <Label text="Minimum Grade (0-100) *" textFill="#2c3e50"><font><Font name="System Bold" size="12"/></font></Label>
                                                <TextField fx:id="txtSchGrade" promptText="e.g. 88.5" style="-fx-background-radius: 8;"/>
                                            </children>
                                        </VBox>

                                        <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                            <children>
                                                <Label text="Location *" textFill="#2c3e50"><font><Font name="System Bold" size="12"/></font></Label>
                                                <TextField fx:id="txtSchLocation" promptText="e.g. Cebu City" style="-fx-background-radius: 8;"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <children>
                                                <Label text="Status" textFill="#2c3e50"><font><Font name="System Bold" size="12"/></font></Label>
                                                <ComboBox fx:id="comboSchStatus" prefHeight="32" maxWidth="1.7976931348623157E308" style="-fx-background-radius: 8;"/>
                                            </children>
                                        </VBox>

                                        <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="3">
                                            <children>
                                                <Label text="Description (optional)" textFill="#2c3e50"><font><Font name="System Bold" size="12"/></font></Label>
                                                <TextArea fx:id="txtSchDescription" prefHeight="70" promptText="Brief description of the scholarship..."
                                                          style="-fx-background-radius: 8;" wrapText="true"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </GridPane>

                                <Label fx:id="lblSchFormStatus" text="" wrapText="true"/>

                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                    <children>
                                        <Button onMouseClicked="#handleClearScholarshipForm" prefHeight="40" prefWidth="140"
                                                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"
                                                text="🔄 Clear Form">
                                            <font><Font name="System Bold" size="13"/></font>
                                        </Button>
                                        <Button fx:id="btnSaveScholarship" onMouseClicked="#handleSaveScholarship"
                                                prefHeight="40" prefWidth="200"
                                                style="-fx-background-color: #800000; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"
                                                text="➕ Add Scholarship">
                                            <font><Font name="System Bold" size="13"/></font>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>

                <!-- FUND MANAGEMENT -->
                <VBox spacing="15.0"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-border-color: #E0E0E0; -fx-border-radius: 15; -fx-padding: 30;">
                    <effect><DropShadow color="#0000001a" radius="10"/></effect>
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <children>
                                <VBox HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="💰  Fund Management" textFill="#212529">
                                            <font><Font name="System Bold" size="20.0"/></font>
                                        </Label>
                                        <Label fx:id="lblFundTotal" text="Total Collected: ₱0.00" textFill="#800000">
                                            <font><Font name="System Bold" size="14.0"/></font>
                                        </Label>
                                    </children>
                                </VBox>
                                <Button onMouseClicked="#handleRefreshFunds" prefHeight="38" prefWidth="120"
                                        style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"
                                        text="🔄 Refresh">
                                    <font><Font name="System Bold" size="13"/></font>
                                </Button>
                            </children>
                        </HBox>

                        <Label text="All donations made by sponsors across every scholarship." textFill="#6C757D"/>

                        <TableView fx:id="tableFunds" prefHeight="250.0">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colFundDate"        text="Date"        prefWidth="150"/>
                                <TableColumn fx:id="colFundSponsor"     text="Sponsor"     prefWidth="180"/>
                                <TableColumn fx:id="colFundScholarship" text="Scholarship" prefWidth="220"/>
                                <TableColumn fx:id="colFundAmount"      text="Amount (₱)"  prefWidth="130"/>
                                <TableColumn fx:id="colFundNote"        text="Note"        prefWidth="220"/>
                            </columns>
                            <placeholder><Label text="No donations recorded yet." textFill="#bdc3c7"/></placeholder>
                        </TableView>

                    </children>
                </VBox>

                <!-- USER MANAGEMENT -->
                <VBox spacing="15.0"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-border-color: #E0E0E0; -fx-border-radius: 15; -fx-padding: 30;">
                    <effect><DropShadow color="#0000001a" radius="10"/></effect>
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <children>
                                <Label text="👥  User Management" textFill="#212529" HBox.hgrow="ALWAYS">
                                    <font><Font name="System Bold" size="20.0"/></font>
                                </Label>
                                <Button onMouseClicked="#handleRefreshUsers" prefHeight="38" prefWidth="120"
                                        style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"
                                        text="🔄 Refresh">
                                    <font><Font name="System Bold" size="13"/></font>
                                </Button>
                            </children>
                        </HBox>

                        <Label text="View all registered users. Change roles or remove accounts." textFill="#6C757D"/>

                        <TableView fx:id="tableUsers" prefHeight="270.0">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colUserID"      text="ID"     prefWidth="50"/>
                                <TableColumn fx:id="colUserName"    text="Name"   prefWidth="180"/>
                                <TableColumn fx:id="colUserEmail"   text="Email"  prefWidth="200"/>
                                <TableColumn fx:id="colUserRole"    text="Role"   prefWidth="90"/>
                                <TableColumn fx:id="colUserCreated" text="Joined" prefWidth="100"/>
                                <TableColumn fx:id="colUserActions" text="Actions" prefWidth="280"/>
                            </columns>
                            <placeholder><Label text="No users found." textFill="#bdc3c7"/></placeholder>
                        </TableView>

                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>